{
  "info": {
    "_postman_id": "42c34be4-76d2-4529-a2f5-b1d8b3719808",
    "name": "NextTurn API Contract Tests",
    "description": "Contract checks for public NextTurn API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('randomSuffix')) {",
          "  const suffix = `${Date.now()}-${Math.floor(Math.random() * 100000)}`;",
          "  pm.collectionVariables.set('randomSuffix', suffix);",
          "  pm.collectionVariables.set('globalUserEmail', `global.${suffix}@example.com`);",
          "  pm.collectionVariables.set('globalUserPassword', 'SecureP@ss1');",
          "  pm.collectionVariables.set('tenantUserEmail', `tenant.${suffix}@example.com`);",
          "  pm.collectionVariables.set('tenantUserPassword', 'SecureP@ss1');",
          "  pm.collectionVariables.set('tenantUserName', 'Contract Tenant User');",
          "  pm.collectionVariables.set('randomProfileId', '11111111-1111-1111-1111-111111111111');",
          "  pm.collectionVariables.set('randomAppointmentId', '22222222-2222-2222-2222-222222222222');",
          "}",
          "",
          "const tomorrow = new Date();",
          "tomorrow.setDate(tomorrow.getDate() + 1);",
          "pm.collectionVariables.set('queryDate', tomorrow.toISOString().slice(0, 10));",
          "pm.collectionVariables.set('slotStart', new Date(Date.now() + 3600 * 1000).toISOString());",
          "pm.collectionVariables.set('slotEnd', new Date(Date.now() + 7200 * 1000).toISOString());"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Organisations",
      "item": [
        {
          "name": "Register Organisation - Positive",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orgName\": \"Contract Org {{randomSuffix}}\",\n  \"addressLine1\": \"1 Contract Street\",\n  \"city\": \"Colombo\",\n  \"postalCode\": \"10000\",\n  \"country\": \"LK\",\n  \"orgType\": \"Government\",\n  \"adminName\": \"Contract Admin\",\n  \"adminEmail\": \"admin.{{randomSuffix}}@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/organisations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "organisations"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.test('organisationId exists', function () { pm.expect(body.organisationId).to.be.a('string').and.not.empty; });",
                  "pm.test('loginPath exists', function () { pm.expect(body.loginPath).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('orgTenantId', body.organisationId);",
                  "pm.collectionVariables.set('orgAdminEmail', `admin.${pm.collectionVariables.get('randomSuffix')}@example.com`);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Organisation - Negative Duplicate",
