  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('randomSuffix')) {",
          "  const suffix = `${Date.now()}-${Math.floor(Math.random() * 100000)}`;",
          "  pm.collectionVariables.set('randomSuffix', suffix);",
          "  pm.collectionVariables.set('globalUserEmail', `global.${suffix}@example.com`);",
          "  pm.collectionVariables.set('globalUserPassword', 'SecureP@ss1');",
          "  pm.collectionVariables.set('tenantUserEmail', `tenant.${suffix}@example.com`);",
          "  pm.collectionVariables.set('tenantUserPassword', 'SecureP@ss1');",
          "  pm.collectionVariables.set('tenantUserName', 'Contract Tenant User');",
          "}",
          ""
        ]
      }
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Get Available Slots",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{tenantAccessToken}}" }, { "key": "X-Tenant-Id", "value": "{{tenantId}}" } ],
            "url": { "raw": "{{baseUrl}}/api/appointments/slots?serviceType=general", "host": ["{{baseUrl}}"], "path": ["api","appointments","slots"], "query": [ { "key": "serviceType", "value": "general" } ] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('slots array exists', function () {",
                  "  pm.expect(body).to.be.an('array');",
                  "});",
                  "if (Array.isArray(body) && body.length > 0) {",
                  "  const first = body[0];",
                  "  const id = first.slotId || first.id || first.slotID || first.slot || null;",
                  "  if (id) {",
                  "    pm.collectionVariables.set('slotId', id);",
                  "    pm.test('slotId saved', function () { pm.expect(pm.collectionVariables.get('slotId')).to.be.a('string'); });",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Booking - Positive",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tenantAccessToken}}" }, { "key": "X-Tenant-Id", "value": "{{tenantId}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"slotId\": \"{{slotId}}\",\n  \"profile\": { \"name\": \"Contract Booking\", \"phone\": null },\n  \"notes\": \"Contract test booking\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/appointments/book", "host": ["{{baseUrl}}"], "path": ["api","appointments","book"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const slotId = pm.collectionVariables.get('slotId');",
                  "if (!slotId) {",
                  "  pm.test('skip create booking when no slot available', function () { pm.expect(true).to.be.true; });",
                  "} else {",
                  "  pm.test('status is 201 or 200', function () {",
                  "    pm.expect([200,201]).to.include(pm.response.code);",
                  "  });",
                  "  const body = pm.response.json();",
                  "  if (body && body.bookingId) { pm.collectionVariables.set('bookingId', body.bookingId); }",
                  "  pm.test('bookingId saved when present', function () {",
                  "    if (body && body.bookingId) pm.expect(body.bookingId).to.be.a('string'); else pm.expect(true).to.be.true;",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{tenantAccessToken}}" }, { "key": "X-Tenant-Id", "value": "{{tenantId}}" } ],
            "url": { "raw": "{{baseUrl}}/api/appointments/my-bookings", "host": ["{{baseUrl}}"], "path": ["api","appointments","my-bookings"] }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status is 200', function () {", "  pm.response.to.have.status(200);", "});", "const body = pm.response.json();", "pm.test('bookings array', function () {", "  pm.expect(body).to.be.an('array');", "});" ] } } ]
        },
        {
          "name": "Reschedule Booking - Conditional",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tenantAccessToken}}" }, { "key": "X-Tenant-Id", "value": "{{tenantId}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"newSlotId\": \"NEW-SLOT-PLACEHOLDER\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/appointments/reschedule", "host": ["{{baseUrl}}"], "path": ["api","appointments","reschedule"] }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "if (!pm.collectionVariables.get('bookingId')) {", "  pm.test('skip reschedule when no booking saved', function () {", "    pm.expect(true).to.be.true;", "  });", "} else {", "  pm.test('reschedule status check', function () {", "    pm.expect([200,400,404]).to.include(pm.response.code);", "  });", "}" ] } } ]
        },
        {
          "name": "Cancel Booking - Conditional",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{tenantAccessToken}}" }, { "key": "X-Tenant-Id", "value": "{{tenantId}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"bookingId\": \"{{bookingId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/appointments/cancel", "host": ["{{baseUrl}}"], "path": ["api","appointments","cancel"] }
          },
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "if (!pm.collectionVariables.get('bookingId')) {", "  pm.test('skip cancel when no booking saved', function () {", "    pm.expect(true).to.be.true;", "  });", "} else {", "  pm.test('cancel status check', function () {", "    pm.expect([200,204,404]).to.include(pm.response.code);", "  });", "}" ] } } ]
        }
      ]
    }
  ],
