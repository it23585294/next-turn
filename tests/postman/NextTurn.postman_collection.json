        {
          "name": "Login Global - Positive Contract",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{globalUserEmail}}\",\n  \"password\": \"{{globalUserPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login-global",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login-global"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('contract fields exist', function () {",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.expect(body).to.have.property('userId');",
                  "  pm.expect(body).to.have.property('name');",
                  "  pm.expect(body).to.have.property('email');",
                  "  pm.expect(body).to.have.property('role');",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
